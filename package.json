{
  "name": "convergio-design",
  "private": true,
  "version": "6.3.2",
  "description": "Ferrari Luce-inspired design system for business dashboards. Part of the Convergio project.",
  "type": "module",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.50.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "esbuild": "^0.27.0",
    "eslint": "^10.0.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^29.0.1",
    "lightningcss": "^1.32.0",
    "serve": "^14.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "build": "pnpm -r run build && node scripts/build-demo.mjs",
    "build:demo": "pnpm build",
    "dev": "npm run build:demo && serve . -l 3000",
    "test": "pnpm exec vitest run tests/unit/consumer-smoke.test.ts tests/unit/shared-shell.test.ts && pnpm -r run test",
    "test:unit": "pnpm test",
    "test:e2e": "playwright test --ignore-snapshots",
    "test:e2e:visual": "playwright test visual-regression",
    "test:e2e:visual:update": "playwright test visual-regression --update-snapshots",
    "clean": "pnpm -r run clean",
    "typecheck": "cd packages/tokens && pnpm exec tsc --noEmit && cd ../elements && pnpm exec tsc --noEmit"
  },
  "license": "MPL-2.0",
  "author": "Roberto D'Angelo (Roberdan)",
  "repository": {
    "type": "git",
    "url": "https://github.com/Roberdan/convergio-design"
  }
}
