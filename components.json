{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "maranello-luce-design-business",
  "version": "2.0.0",
  "description": "Ferrari Luce-inspired design system for business dashboards",
  "layers": {
    "css-only": "Pure CSS components via class names, no JS required",
    "headless-js": "Vanilla JS/TS functions that render into a container element",
    "web-component": "Custom elements (mn-* tags) wrapping headless-js layer"
  },
  "themes": ["editorial", "nero", "avorio", "colorblind"],
  "components": [
    {
      "name": "Sparkline",
      "layer": "headless-js",
      "import": "maranello-luce-design-business/charts",
      "function": "sparkline",
      "cssImport": "maranello-luce-design-business/css/charts.css",
      "wcTag": "mn-chart",
      "domSafe": true,
      "canvasOnly": true,
      "description": "Compact line chart with fill gradient and trailing dot indicator",
      "dataContract": "SparklineOptions",
      "whenToUse": ["inline KPI trends", "sparkline in table cells", "compact time series"],
      "themes": ["nero", "avorio", "editorial", "colorblind"]
    },
    {
      "name": "Donut",
      "layer": "headless-js",
      "import": "maranello-luce-design-business/charts",
      "function": "donut",
      "cssImport": "maranello-luce-design-business/css/charts-live-donut-bar.css",
      "wcTag": "mn-chart",
      "domSafe": true,
      "canvasOnly": true,
      "description": "Segmented ring chart with configurable thickness and gap",
      "dataContract": "DonutSegment[]",
      "whenToUse": ["proportional breakdown", "category distribution", "completion percentage"],
      "themes": ["nero", "avorio", "editorial", "colorblind"]
    },
    {
      "name": "BarChart",
      "layer": "headless-js",
      "import": "maranello-luce-design-business/charts",
      "function": "barChart",
      "cssImport": "maranello-luce-design-business/css/charts-live-donut-bar.css",
      "wcTag": "mn-chart",
      "domSafe": true,
      "canvasOnly": true,
      "description": "Vertical bar chart with rounded tops and optional labels",
      "dataContract": "BarDataItem[]",
      "whenToUse": ["category comparison", "monthly totals", "ranked values"],
      "themes": ["nero", "avorio", "editorial", "colorblind"]
    },
    {
      "name": "AreaChart",
      "layer": "headless-js",
      "import": "maranello-luce-design-business/charts",
      "function": "areaChart",
      "cssImport": "maranello-luce-design-business/css/charts.css",
      "wcTag": "mn-chart",
      "domSafe": true,
      "canvasOnly": true,
      "description": "Multi-dataset area chart with smooth curves and gradient fills",
      "dataContract": "AreaDataset[]",
      "whenToUse": ["time series overlay", "trend comparison", "volume over time"],
      "themes": ["nero", "avorio", "editorial", "colorblind"]
    },
    {
      "name": "Radar",
      "layer": "headless-js",
      "import": "maranello-luce-design-business/charts",
      "function": "radar",
      "cssImport": "maranello-luce-design-business/css/charts-treemap-radar-gantt.css",
      "wcTag": "mn-chart",
      "domSafe": true,
      "canvasOnly": true,
      "description": "Spider/radar chart with polygon grid, axis labels, and dot markers",
      "dataContract": "RadarDataItem[]",
      "whenToUse": ["multi-dimensional scoring", "competency assessment", "feature comparison"],
      "themes": ["nero", "avorio", "editorial", "colorblind"]
    },
    {
      "name": "Bubble",
      "layer": "headless-js",
      "import": "maranello-luce-design-business/charts",
      "function": "bubble",
      "cssImport": "maranello-luce-design-business/css/charts.css",
      "wcTag": "mn-chart",
      "domSafe": true,
      "canvasOnly": true,
      "description": "Scatter plot with sized bubbles for 3-dimensional data",
      "dataContract": "BubbleDataItem[]",
      "whenToUse": ["3D data visualization", "portfolio analysis", "market mapping"],
      "themes": ["nero", "avorio", "editorial", "colorblind"]
    },
    {
      "name": "LiveGraph",
      "layer": "headless-js",
      "import": "maranello-luce-design-business/charts",
      "function": "liveGraph",
      "cssImport": "maranello-luce-design-business/css/charts-live-donut-bar.css",
      "wcTag": "mn-chart",
      "domSafe": true,
      "canvasOnly": true,
      "description": "Real-time line graph with glow effect and optional red limit line",
      "dataContract": "LiveGraphOptions",
      "whenToUse": ["real-time monitoring", "live metrics", "streaming data"],
      "themes": ["nero", "avorio", "editorial", "colorblind"]
    },
    {
      "name": "HalfGauge",
      "layer": "headless-js",
      "import": "maranello-luce-design-business/charts",
      "function": "halfGauge",
      "cssImport": "maranello-luce-design-business/css/charts-gauge-temp-progress.css",
      "wcTag": "mn-chart",
      "domSafe": true,
      "canvasOnly": true,
      "description": "Semicircular gauge with gradient arc and min/max labels",
      "dataContract": "HalfGaugeOptions",
      "whenToUse": ["score display", "health indicator", "capacity meter"],
      "themes": ["nero", "avorio", "editorial", "colorblind"]
    },
    {
      "name": "HBarChart",
