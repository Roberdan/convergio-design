{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "@convergio/design-elements",
  "version": "6.3.2",
  "description": "Ferrari Luce-inspired design system for business dashboards",
  "detailCatalog": "./components-detail.json",
  "layers": {
    "css-only": "Pure CSS components via class names, no JS required",
    "headless-js": "Vanilla JS/TS functions that render into a container element",
    "web-component": "Custom elements (mn-* tags) wrapping headless-js layer"
  },
  "themes": [
    "editorial",
    "nero",
    "avorio",
    "colorblind",
    "sugar",
    "navy"
  ],
  "subpackages": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./css": {
      "import": "./dist/css/index.css"
    },
    "./wc": {
      "types": "./dist/types/wc/index.d.ts",
      "import": "./dist/esm/wc/index.js",
      "require": "./dist/cjs/wc/index.cjs"
    },
    "./register-all": {
      "types": "./dist/types/wc/register-all.d.ts",
      "import": "./dist/esm/wc/register-all.js",
      "require": "./dist/cjs/wc/register-all.cjs"
    },
    "./charts": {
      "types": "./dist/types/charts/index.d.ts",
      "import": "./dist/esm/charts/index.js",
      "require": "./dist/cjs/charts/index.cjs"
    },
    "./gantt": {
      "types": "./dist/types/gantt/index.d.ts",
      "import": "./dist/esm/gantt/index.js",
      "require": "./dist/cjs/gantt/index.cjs"
    },
    "./gauge": {
      "types": "./dist/types/gauge/index.d.ts",
      "import": "./dist/esm/gauge/index.js",
      "require": "./dist/cjs/gauge/index.cjs"
    },
    "./controls": {
      "types": "./dist/types/controls/index.d.ts",
      "import": "./dist/esm/controls/index.js",
      "require": "./dist/cjs/controls/index.cjs"
    },
    "./forms": {
      "types": "./dist/types/forms/index.d.ts",
      "import": "./dist/esm/forms/index.js",
      "require": "./dist/cjs/forms/index.cjs"
    },
    "./knowledge": {
      "import": "./dist/knowledge/ckb.json"
    }
  },
  "webComponents": [
    "mn-a11y",
    "mn-async-select",
    "mn-chart",
    "mn-chat",
    "mn-command-palette",
    "mn-dashboard",
    "mn-data-table",
    "mn-date-picker",
    "mn-detail-panel",
    "mn-entity-workbench",
    "mn-facet-workbench",
    "mn-ferrari-control",
    "mn-funnel",
    "mn-gantt",
    "mn-gauge",
    "mn-header-shell",
    "mn-kanban-board",
    "mn-hbar",
    "mn-map",
    "mn-mapbox",
    "mn-modal",
    "mn-okr",
    "mn-profile",
    "mn-section-nav",
    "mn-speedometer",
    "mn-system-status",
    "mn-tab",
    "mn-tabs",
    "mn-theme-rotary",
    "mn-theme-toggle",
    "mn-toast"
  ],
  "cssModules": [
    "base.css",
    "tokens.css",
    "themes.css",
    "themes-base.css",
    "components.css",
    "controls.css",
    "forms.css",
    "layouts.css",
    "extended.css",
    "patterns.css",
    "animations.css",
    "gauge.css",
    "icons.css",
    "utilities.css",
    "accessibility.css",
    "composition.css",
