      "wcTag": "mn-hbar",
      "domSafe": false,
      "canvasOnly": false,
      "description": "DOM-based horizontal bar chart with tooltips, sorting, and animation",
      "dataContract": "HBarChartOptions",
      "whenToUse": ["ranked lists", "horizontal comparison", "progress bars"],
      "themes": ["nero", "avorio", "editorial", "colorblind"]
    },
    {
      "name": "FerrariGauge",
      "layer": "headless-js",
      "import": "maranello-luce-design-business/gauge",
