      "cssImport": "maranello-luce-design-business/css/gauge.css",
      "wcTag": "mn-gauge",
      "domSafe": true,
      "canvasOnly": true,
      "description": "Ferrari-inspired radial gauge with animated needle, sub-dials, and complications",
      "dataContract": "GaugeConfig",
      "whenToUse": ["KPI display", "score visualization", "progress indicator"],
      "themes": ["nero", "avorio", "editorial", "colorblind"]
    },
    {
      "name": "Speedometer",
      "layer": "headless-js",
      "import": "maranello-luce-design-business",
      "function": "speedometer",
      "cssImport": "maranello-luce-design-business/css/charts-gauge-temp-progress.css",
      "wcTag": "mn-speedometer",
      "domSafe": true,
      "canvasOnly": true,
      "description": "Animated needle speedometer with ticks, arc indicator, and optional bar",
      "dataContract": "SpeedometerOptions",
      "whenToUse": ["velocity metrics", "performance gauge", "speed indicator"],
      "themes": ["nero", "avorio", "editorial", "colorblind"]
    },
    {
      "name": "Gantt",
      "layer": "headless-js",
      "import": "maranello-luce-design-business/gantt",
      "function": "gantt",
      "cssImport": "maranello-luce-design-business/css/charts-gantt-timeline.css",
      "wcTag": "mn-gantt",
