      "gauge-engine-class.ts",
      "speedometer-palette.ts",
      "speedometer-draw.ts",
      "h-bar-chart-draw.ts",
      "data-binding-events.ts",
      "data-binding-ui.ts",
      "icons-az.ts",
      "detail-panel.ts",
      "detail-panel-ui.ts",
      "detail-panel-editors.ts",
      "detail-panel-renderers.ts",
      "a11y-panel.ts",
      "a11y-panel-dom.ts",
      "controls-dialogs.ts",
      "controls-drag.ts",
      "map-view.ts",
      "map-view-events.ts",
      "map-view-helpers.ts"
    ]
