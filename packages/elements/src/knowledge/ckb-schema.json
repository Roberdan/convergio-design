{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://convergio.dev/schemas/ckb.json",
  "title": "Convergio Design — Component Knowledge Base",
  "description": "Machine-readable catalog of all convergio-design components, their data shapes, composition rules, and API-to-component mapping hints. Auto-generated from source.",
  "type": "object",
  "required": ["version", "generated", "packageVersion", "webComponents", "tsModules", "compositionRules", "mappingHints", "workflowTemplates"],
  "properties": {
    "version": {
      "type": "string",
      "description": "CKB schema version"
    },
    "generated": {
      "type": "string",
      "format": "date-time",
      "description": "When this CKB was generated"
    },
    "packageVersion": {
      "type": "string",
      "description": "Version of @convergio/design-elements this CKB describes"
    },
    "webComponents": {
      "type": "array",
      "description": "All registered Web Components (mn-* custom elements)",
      "items": { "$ref": "#/$defs/WebComponent" }
    },
    "tsModules": {
      "type": "object",
      "description": "All TypeScript API modules exported from the package",
      "additionalProperties": { "$ref": "#/$defs/TsModule" }
    },
    "compositionRules": {
      "type": "array",
      "description": "Patterns for combining components together",
      "items": { "$ref": "#/$defs/CompositionRule" }
    },
    "mappingHints": {
      "type": "array",
      "description": "Heuristics for mapping API response shapes to components",
      "items": { "$ref": "#/$defs/MappingHint" }
    },
    "workflowTemplates": {
      "type": "array",
      "description": "Semantic workflow-to-component mappings for agent-driven composition",
      "items": { "$ref": "#/$defs/WorkflowTemplate" }
    },
    "themes": {
      "type": "array",
      "description": "Available themes",
      "items": { "$ref": "#/$defs/Theme" }
    },
    "constraints": {
      "$ref": "#/$defs/Constraints",
      "description": "Non-negotiable rules for using the design system"
    }
  },
  "$defs": {
    "WebComponent": {
      "type": "object",
      "required": ["tag", "sourceFile", "description", "attributes", "events"],
      "properties": {
        "tag": {
          "type": "string",
          "pattern": "^mn-",
          "description": "Custom element tag name"
        },
        "sourceFile": {
          "type": "string",
          "description": "Path relative to packages/elements/"
        },
        "description": {
          "type": "string",
          "description": "What this component does"
        },
        "attributes": {
          "type": "array",
          "items": { "type": "object", "required": ["name", "type"], "properties": { "name": { "type": "string" }, "type": { "enum": ["string", "number", "boolean", "json"] }, "description": { "type": "string" }, "default": {} } }
        },
        "events": {
          "type": "array",
          "items": { "type": "object", "required": ["name"], "properties": { "name": { "type": "string" }, "detailShape": { "type": "string" }, "bubbles": { "type": "boolean" } } }
        },
        "imports": { "type": "array", "items": { "type": "string" }, "description": "TS module dependencies" },
        "bestFor": { "type": "array", "items": { "type": "string" }, "description": "Use cases this component excels at" },
        "dataShape": { "type": "string", "description": "Primary data input interface name" },
        "ssrSafe": { "type": "boolean", "default": false, "description": "SSR-safe (always false for WCs)" },
        "themeAware": { "type": "boolean", "default": true, "description": "Adapts to all 6 themes" },
        "importPath": { "type": "string", "description": "ESM import path" }
      }
    },
    "TsModule": {
      "type": "object",
      "required": ["sourceFile", "description", "exports"],
      "properties": {
        "sourceFile": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "exports": {
          "type": "object", "description": "Named exports with signatures",
          "additionalProperties": { "type": "object", "properties": { "signature": { "type": "string" }, "description": { "type": "string" }, "kind": { "enum": ["function", "class", "constant", "type", "interface"] } } }
        },
        "types": {
          "type": "object", "description": "TypeScript interfaces/types",
          "additionalProperties": { "type": "object", "properties": { "fields": { "type": "object" }, "description": { "type": "string" } } }
        },
        "bestFor": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dataShape": {
          "type": "string",
          "description": "Primary data input interface name"
        },
        "controllerMethods": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Methods available on the returned controller"
        },
        "importPath": {
          "type": "string",
          "description": "ESM import path"
        }
      }
    },
    "CompositionRule": {
      "type": "object",
      "required": ["id", "pattern", "components"],
      "properties": {
        "id": { "type": "string" },
        "pattern": {
          "type": "string",
          "description": "Name of the composition pattern"
        },
        "description": {
          "type": "string"
        },
        "components": { "type": "array", "items": { "type": "string" }, "description": "Component IDs involved" },
        "layout": { "type": "string", "description": "Recommended layout" },
        "example": { "type": "string", "description": "Brief code example" },
        "apiPattern": { "type": "string", "description": "API pattern this composition responds to" },
        "prerequisites": { "type": "array", "items": { "type": "string" }, "description": "CSS/JS imports needed" }
      }
    },
    "MappingHint": {
      "type": "object",
      "required": ["id", "apiPattern", "suggestedComponent"],
      "properties": {
        "id": { "type": "string" },
        "apiPattern": { "type": "string", "description": "API pattern description" },
        "httpMethod": { "enum": ["GET", "POST", "PUT", "DELETE", "WS", "SSE", "ANY"] },
        "responseShape": { "type": "string", "description": "Expected response shape" },
        "suggestedComponent": { "type": "string", "description": "Primary component ID" },
        "alternativeComponents": { "type": "array", "items": { "type": "string" } },
        "updateStrategy": { "enum": ["static", "poll", "websocket", "sse"], "description": "Data freshness strategy" },
        "compositionRule": { "type": "string", "description": "Related composition rule ID" },
        "dataTransform": { "type": "string", "description": "API response to component data transform" }
      }
    },
    "WorkflowTemplate": {
      "type": "object",
      "required": ["workflow", "label", "description", "components", "compositionRules", "layout", "tags"],
      "properties": {
        "workflow": { "type": "string", "description": "Unique workflow ID (kebab-case)" },
        "label": { "type": "string", "description": "Human-readable workflow name" },
        "description": { "type": "string", "description": "What this workflow builds" },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "role"],
            "properties": {
              "id": { "type": "string", "description": "Component tag (mn-*) or TS module name" },
              "role": { "type": "string", "description": "What this component does in the workflow" },
              "importPath": { "type": "string" }
            }
          }
        },
        "compositionRules": { "type": "array", "items": { "type": "string" }, "description": "IDs of related composition rules" },
        "layout": { "type": "string", "description": "Recommended layout strategy" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Searchable keywords for intent matching" },
        "starter": {
          "type": "object",
          "properties": {
            "package": { "type": "string" },
            "description": { "type": "string" },
            "entryFunction": { "type": "string" }
          }
        },
        "dataShapes": { "type": "array", "items": { "type": "string" }, "description": "Mapping hint IDs this workflow consumes" }
      }
    },
    "Theme": {
      "type": "object",
      "required": ["id", "bodyClass", "accent"],
      "properties": {
        "id": { "type": "string" },
        "bodyClass": { "type": "string" },
        "accent": { "type": "string" },
        "surface": { "type": "string" },
        "variant": { "enum": ["dark", "light"] },
        "description": { "type": "string" }
      }
    },
    "Constraints": {
      "type": "object",
      "properties": {
        "safari": {
          "type": "array",
          "items": { "type": "string" },
          "description": "APIs that must NOT be used (Safari/WebKit compat)"
        },
        "tokens": {
          "type": "string",
          "description": "Token usage rules"
        },
        "wcag": {
          "type": "string",
          "description": "WCAG compliance level"
        },
        "maxFileLines": { "type": "number" },
        "cssLayers": { "type": "boolean" },
        "noInnerHTML": { "type": "boolean" },
        "ssrRequirements": {
          "type": "string",
          "description": "SSR/framework requirements"
        }
      }
    }
  }
}
