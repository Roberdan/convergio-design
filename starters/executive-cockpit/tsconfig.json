{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "declarationDir": "dist/types",
    "declaration": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": ["src/**/*"]
}
